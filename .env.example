# Public application URL. Clearo redirects and webhooks must be able to reach it.
PUBLIC_BASE_URL=https://your-domain.example
PORT=4173
NODE_ENV=production

# Generate a NEW Clearo API key and webhook secret. Never reuse credentials
# that were posted in chat or place these values in index.html.
CLEARO_API_KEY=
CLEARO_WEBHOOK_SECRET=
CLEARO_CURRENCY=ILS
CLEARO_AMOUNT=249
PAYMENT_SURCHARGE_PERCENT=4.5
# Clearo adds this percent on top of the payment-link amount. The server divides
# the displayed customer price by (1 + percent/100) so the buyer still pays the
# price shown on the site.

# Admin login and cryptographic secrets (use long random values).
ADMIN_PASSWORD=
SESSION_SECRET=
INVENTORY_ENCRYPTION_KEY=

# Optional email delivery and owner alerts through Resend.
RESEND_API_KEY=
EMAIL_FROM=Pro18 <orders@your-domain.example>
OWNER_EMAIL=

# Optional generic owner notification endpoint (Slack/Discord/Make/Zapier).
OWNER_NOTIFICATION_WEBHOOK_URL=

# Optional Meta (Facebook) Pixel ID for conversion tracking on public storefront pages.
META_PIXEL_ID=
